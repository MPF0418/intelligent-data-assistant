{
  "name": "smart-data-insight",
  "version": "6.0.1",
  "description": "智能数据洞察助手 V6.0 - Windows桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win --x64 --target=portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.smartdatainsight.app",
    "productName": "智能数据洞察助手",
    "asar": false,
    "files": [
      "**/*"
    ],
    "copyright": "Copyright © 2026 智能数据洞察助手",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "智能数据洞察助手-${version}-portable.exe"
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
