{
  "version": "1.0",
  "last_updated": "2026-03-28",
  "description": "智能数据分析助手 - 意图表定义",
  "intents": [
    {
      "type": "query_value",
      "name": "数值查询",
      "description": "查询某个筛选条件下的具体数值",
      "required_fields": ["filter_column", "filter_value", "target_column"],
      "optional_fields": [],
      "example": "广东的销售额是多少",
      "vectorizable": true,
      "keywords": ["是多少", "有多少", "查询", "数值", "多少"]
    },
    {
      "type": "chart",
      "name": "绘制图表",
      "description": "根据数据绘制可视化图表",
      "required_fields": ["chart_type"],
      "optional_fields": ["x_axis", "y_axis", "group_by"],
      "example": "绘制柱状图",
      "vectorizable": true,
      "keywords": ["绘制", "画", "图表", "可视化", "柱状图", "折线图", "饼图", "条形图"],
      "chart_types": ["bar", "line", "pie", "scatter", "area", "radar"]
    },
    {
      "type": "sort",
      "name": "排序",
      "description": "对数据进行排序",
      "required_fields": ["sort_column"],
      "optional_fields": ["sort_direction", "limit"],
      "example": "按销售额从大到小排序",
      "vectorizable": true,
      "keywords": ["排序", "从高到低", "从低到高", "升序", "降序", "由大到小", "由小到大"],
      "directions": ["asc", "desc", "升序", "降序"]
    },
    {
      "type": "filter",
      "name": "筛选",
      "description": "根据条件筛选数据",
      "required_fields": ["filter_column", "filter_value"],
      "optional_fields": ["operator"],
      "example": "筛选男性记录",
      "vectorizable": true,
      "keywords": ["筛选", "过滤", "查找", "只看", "只要"],
      "operators": ["=", "!=", ">", "<", ">=", "<=", "包含", "不包含"]
    },
    {
      "type": "aggregate",
      "name": "聚合计算",
      "description": "对数据进行统计计算",
      "required_fields": ["aggregate_column", "aggregate_method"],
      "optional_fields": ["group_by"],
      "example": "计算销售额总和",
      "vectorizable": true,
      "keywords": ["总和", "合计", "求和", "平均", "最大值", "最小值", "计数", "计算"],
      "methods": ["sum", "avg", "max", "min", "count", "mean"]
    },
    {
      "type": "compare",
      "name": "对比分析",
      "description": "对比不同类别或时期的数据",
      "required_fields": ["compare_column", "group_by"],
      "optional_fields": ["compare_type"],
      "example": "对比各地区的销售额",
      "vectorizable": true,
      "keywords": ["对比", "比较", "差异", "区别"],
      "compare_types": ["ratio", "difference", "percentage"]
    },
    {
      "type": "trend",
      "name": "趋势分析",
      "description": "分析数据随时间的变化趋势",
      "required_fields": ["time_column", "value_column"],
      "optional_fields": ["trend_type"],
      "example": "分析销售额的变化趋势",
      "vectorizable": true,
      "keywords": ["趋势", "变化", "走势", "增长", "下降", "波动"],
      "trend_types": ["growth", "decline", "fluctuation", "seasonal"]
    },
    {
      "type": "ranking",
      "name": "排名",
      "description": "对数据进行排名",
      "required_fields": ["rank_column"],
      "optional_fields": ["rank_count", "group_by", "direction"],
      "example": "销售额前10的产品",
      "vectorizable": true,
      "keywords": ["排名", "前", "后", "top", "bottom", "第几"],
      "directions": ["desc", "asc"]
    },
    {
      "type": "export",
      "name": "导出数据",
      "description": "导出数据到指定格式",
      "required_fields": ["export_format"],
      "optional_fields": ["export_columns", "filename"],
      "example": "导出为Excel",
      "vectorizable": false,
      "keywords": ["导出", "下载", "保存"],
      "formats": ["excel", "csv", "json", "pdf"]
    },
    {
      "type": "extreme",
      "name": "极值查询",
      "description": "查询最大/最小值",
      "required_fields": ["target_column", "extreme_type"],
      "optional_fields": ["group_by"],
      "example": "销售额最高的产品",
      "vectorizable": true,
      "keywords": ["最高", "最低", "最大", "最小", "最好", "最差"]
    }
  ],
  "intent_groups": {
    "query": ["query_value", "extreme", "aggregate"],
    "visualization": ["chart", "trend", "compare"],
    "data_operation": ["filter", "sort", "ranking"],
    "output": ["export"]
  },
  "clarification_templates": {
    "chart": {
      "missing_x_axis": "请问X轴要显示什么字段？",
      "missing_y_axis": "请问Y轴要显示什么字段？",
      "missing_chart_type": "请问要绘制哪种图表？（柱状图/折线图/饼图等）"
    },
    "sort": {
      "missing_column": "请问要按哪个字段排序？",
      "missing_direction": "请问排序方向是升序还是降序？"
    },
    "filter": {
      "missing_column": "请问要筛选哪个字段？",
      "missing_value": "请问筛选的具体值是什么？"
    },
    "aggregate": {
      "missing_column": "请问要对哪个字段进行计算？",
      "missing_method": "请问要计算总和、平均值还是其他？"
    },
    "ranking": {
      "missing_column": "请问要根据哪个字段排名？"
    }
  }
}
